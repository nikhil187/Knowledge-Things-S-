# Optional: Override API base URL (default: same host in prod, localhost:3001 in dev)
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# Optional: Override WebSocket URL when frontend and backend are on different hosts
# e.g. Vercel (frontend) + Render (backend)
# NEXT_PUBLIC_SOCKET_URL=https://your-backend.example.com
